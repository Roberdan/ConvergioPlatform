#!/usr/bin/env zsh
# convergio — ConvergioPlatform Swarm CLI v2.1.0
# Model-agnostic, tool-agnostic, machine-agnostic agent orchestration
# All state managed by daemon core on :8420
set -euo pipefail

PLATFORM_DIR="${CONVERGIO_PLATFORM_DIR:-$HOME/GitHub/ConvergioPlatform}"
TOGGLE="$PLATFORM_DIR/scripts/platform/convergio-toggle.sh"
BUS="$PLATFORM_DIR/scripts/platform/convergio-bus.sh"
DAEMON_URL="${CONVERGIO_DAEMON_URL:-http://localhost:8420}"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[0;33m'
C='\033[0;36m'; B='\033[1m'; D='\033[2m'; N='\033[0m'

# Source modular operations — inherits all vars and color codes above
# shellcheck source=convergio-run-ops.sh
source "$PLATFORM_DIR/scripts/platform/convergio-run-ops.sh"
# shellcheck source=convergio-daemon-ops.sh
source "$PLATFORM_DIR/scripts/platform/convergio-daemon-ops.sh"

# name|description|invoke|default_model|default_tool
AGENT_LIST=(
  "planner|Plan creation + orchestration|/planner|opus|claude"
  "executor|Task execution with TDD|/execute|codex|copilot"
  "thor|Quality validation (10 gates)|/validate|opus|claude"
  "prompt|Requirements extraction|/prompt|opus|claude"
  "reviewer|Independent plan review|@plan-reviewer|sonnet|claude"
  "rex|Code review — patterns + security|@rex-code-reviewer|haiku|claude"
  "debugger|Adversarial 3-hypothesis debugging|@adversarial-debugger|sonnet|claude"
  "postmortem|Plan execution analysis|@plan-post-mortem|opus|claude"
  "optimizer|Context + token optimization|/optimize-instructions|opus|claude"
  "auditor|Deep cross-validated repo audit|@deep-repo-auditor|opus|claude"
  "convergio|Platform control plane expert|@Convergio|sonnet|claude"
  "llm|Local LLM infrastructure|@ConvergioLLM|sonnet|claude"
  "check|Quick session status recap|/check|mini|copilot"
  "ali|Chief of Staff — orchestrates virtual teams|@ali-orchestrator|opus|claude"
)

get_agent() {
  for entry in "${AGENT_LIST[@]}"; do
    [[ "${entry%%|*}" == "$1" ]] && echo "$entry" && return 0
  done
  return 1
}

_daemon_ok() { curl -sf --connect-timeout 1 "$DAEMON_URL/api/ipc/status" > /dev/null 2>&1; }

cmd_help() {
  echo -e "${B}convergio${N} — Swarm CLI v2.1.0\n"
  echo -e "${B}Solve (virtual organization):${N}"
  echo -e "  convergio ${C}solve \"problem\"${N}            Ali assembles a team and solves it"
  echo -e "\n${B}Agents (any model/tool):${N}"
  echo -e "  convergio ${C}<agent> [name] [--tool T]${N}  Launch (tools: claude|copilot|opencode|local)"
  echo -e "  convergio ${C}as <name> [--tool T]${N}       Custom name"
  echo -e "  convergio ${C}list${N}                       Available agents"
  echo -e "  convergio ${C}menu${N}                       Interactive"
  echo -e "\n${B}Communication (daemon API):${N}"
  echo -e "  convergio ${C}who${N}                        Active agents"
  echo -e "  convergio ${C}msg <from> <to> <msg>${N}      Send message"
  echo -e "  convergio ${C}read <name>${N}                Read messages"
  echo -e "  convergio ${C}broadcast <from> <msg>${N}     Send to all"
  echo -e "\n${B}Toggle:${N}"
  echo -e "  convergio ${C}on|off|status${N}              Enable/disable/check"
  echo -e "\n${B}Workflow:${N}"
  echo -e "  convergio ${C}plans|session${N}              Plan status"
  echo -e "  convergio ${C}autopilot [watch]${N}          Auto execute→Thor→merge loop"
  echo -e "  convergio ${C}auto-update${N}                Analyze + propose improvements"
  echo -e "\n${B}Run control:${N}"
  echo -e "  convergio ${C}stop [run_id]${N}              Stop all agents (or a specific run)"
  echo -e "  convergio ${C}pause <run_id>${N}             Pause a running execution"
  echo -e "  convergio ${C}resume <run_id>${N}            Resume a paused execution"
  echo -e "\n${B}Telemetry & Learning:${N}"
  echo -e "  convergio ${C}models|skills|alerts${N}"
  echo -e "  convergio ${C}metrics${N}                        System metrics (daemon)"
  echo -e "  convergio ${C}metrics runs${N}                   List execution runs"
  echo -e "  convergio ${C}metrics run <id>${N}               Per-run: duration, cost, agents, tasks"
  echo -e "  convergio ${C}learnings [analyze|promote]${N} Knowledge system"
  echo -e "  convergio ${C}collect-metrics${N}             Snapshot system telemetry"
  echo -e "  convergio ${C}watch-agents${N}               Real-time agent activity stream"
  echo -e "\n${B}Daemon:${N}"
  echo -e "  convergio ${C}daemon start|stop|restart${N}  Manage daemon process"
  echo -e "  convergio ${C}daemon install|uninstall${N}   Auto-start on boot"
  echo -e "  convergio ${C}daemon status|logs${N}         Health + logs"
  echo -e "\n${B}Maintenance:${N}"
  echo -e "  convergio ${C}sync-agents|import-agents${N}"
  echo -e "  convergio ${C}heartbeat${N}                  Mesh status"
}

cmd_list() {
  echo -e "${B}Available Agents${N}\n"
  printf "  ${B}%-12s %-38s %-8s %s${N}\n" "NAME" "ROLE" "MODEL" "TOOL"
  echo "  ──────────── ────────────────────────────────────── ──────── ────────"
  for entry in "${AGENT_LIST[@]}"; do
    IFS='|' read -r name desc invoke model tool <<< "$entry"
    printf "  ${C}%-12s${N} %-38s ${D}%-8s %s${N}\n" "$name" "$desc" "$model" "$tool"
  done
  echo -e "\n${D}convergio <name> [custom-name] [--tool claude|copilot|opencode]${N}"
}

cmd_who()       { "$BUS" who; }
cmd_msg()       { "$BUS" send "$@"; }
cmd_read_msg()  { "$BUS" read "$@"; }
cmd_broadcast() { "$BUS" broadcast "$@"; }
cmd_models()    { "$BUS" models; }
cmd_metrics() {
  local sub="${1:-}"
  case "$sub" in
    run)   shift; bash "$PLATFORM_DIR/scripts/platform/convergio-metrics.sh" run "${1:-}" ;;
    runs)  bash "$PLATFORM_DIR/scripts/platform/convergio-metrics.sh" runs ;;
    *)     "$BUS" metrics ;;
  esac
}
cmd_skills()    { "$BUS" skills; }

cmd_alerts() {
  _daemon_ok && curl -sf "$DAEMON_URL/api/dashboard/notifications" 2>/dev/null \
    | python3 -m json.tool 2>/dev/null || echo "Daemon not running or no alerts."
}

cmd_plans()    { bash "$PLATFORM_DIR/claude-config/scripts/plan-db.sh" list 1 2>/dev/null || echo "N/A"; }
cmd_session()  { bash "$PLATFORM_DIR/claude-config/scripts/session-check.sh" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "N/A"; }
cmd_learnings(){ bash "$PLATFORM_DIR/claude-config/scripts/session-learnings.sh" summary 2>/dev/null || echo "N/A"; }

cmd_auto_update() {
  "$TOGGLE" on 2>/dev/null
  echo -e "${B}Convergio Auto-Update${N}\n"
  local p="Sei context-optimizer + post-mortem. 1) session-learnings.sh summary 2) Web: novita AI 3) claude-config/ inefficienze 4) plan-db.sh get-failures 5) Proponi diff. NO apply senza ok."
  cd "$PLATFORM_DIR"; command -v claude &>/dev/null && claude "$p" || echo "$p"
}

cmd_sync_agents() {
  echo -e "${B}Syncing agent definitions...${N}"
  local src="$PLATFORM_DIR/claude-config/agents"
  echo "  Source: $src (canonical)"
  echo "  Claude: ~/.claude/agents/ (via global symlink)"
  find -L "$src" -name "*.md" | while read f; do
    local aname
    aname=$(head -10 "$f" | grep '^name:' | cut -d' ' -f2)
    [ -n "$aname" ] && echo "  $aname"
  done
  echo -e "\n${G}Done.${N}"
}

cmd_heartbeat() { bash "$PLATFORM_DIR/scripts/mesh/mesh-heartbeat.sh" 2>/dev/null || echo "Mesh N/A."; }

# ─── Parse --tool flag ────────────────────────────────────────────────
TOOL_OVERRIDE=""
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--tool" ]]; then TOOL_OVERRIDE="__next__"
  elif [[ "$TOOL_OVERRIDE" == "__next__" ]]; then TOOL_OVERRIDE="$arg"
  else ARGS+=("$arg"); fi
done
set -- "${ARGS[@]:-}"

case "${1:-help}" in
  help|--help|-h)     cmd_help ;;
  list|ls)            cmd_list ;;
  menu|select)        cmd_menu ;;
  on|enable)          "$TOGGLE" on ;;
  off|disable)        "$TOGGLE" off ;;
  status|st)          "$TOGGLE" status; _daemon_ok && echo "  Daemon: running" || echo "  Daemon: stopped" ;;
  as)                 shift; cmd_named "${1:-}" "$TOOL_OVERRIDE" ;;
  who)                cmd_who ;;
  msg|send)           shift; cmd_msg "$@" ;;
  read)               shift; cmd_read_msg "$@" ;;
  broadcast)          shift; cmd_broadcast "$@" ;;
  plans)              cmd_plans ;;
  session|sess)       cmd_session ;;
  learnings)          shift; bash "$PLATFORM_DIR/scripts/platform/convergio-learnings.sh" "${1:-summary}" ;;
  auto-update|update) cmd_auto_update ;;
  models)             cmd_models ;;
  metrics)            shift; cmd_metrics "${@}" ;;
  skills)             cmd_skills ;;
  alerts)             cmd_alerts ;;
  sync-agents)        cmd_sync_agents ;;
  solve)              shift; cmd_solve "$@" ;;
  stop)               shift; cmd_stop "${1:-}" ;;
  pause)              shift; cmd_pause "${1:-}" ;;
  resume)             shift; cmd_resume "${1:-}" ;;
  sync)               shift; bash "$PLATFORM_DIR/scripts/platform/convergio-sync.sh" "$@" ;;
  autopilot)          shift; bash "$PLATFORM_DIR/scripts/platform/convergio-autopilot.sh" "${1:-once}" ;;
  collect-metrics)    bash "$PLATFORM_DIR/scripts/platform/convergio-metrics.sh" collect ;;
  org)                shift; bash "$PLATFORM_DIR/scripts/platform/convergio-org.sh" "${1:-help}" "${2:-}" ;;
  watch-agents)
    echo "Watching agent activity (Ctrl+C to stop)..."
    curl -sf -N "$DAEMON_URL/ws/dashboard" 2>/dev/null | python3 -c "
import sys,json
for line in sys.stdin:
  line=line.strip()
  if not line: continue
  try:
    d=json.loads(line)
    t=d.get('type','?')
    if 'agent' in t or 'ipc' in t:
      print(f'[{t}] {json.dumps(d,indent=None)}')
  except: pass
" 2>/dev/null || echo "Daemon not running or WS not available. Start daemon first." ;;
  import-agents)      shift; bash "$PLATFORM_DIR/scripts/platform/convergio-import-agents.sh" "${1:-}" ;;
  daemon)             shift; cmd_daemon "${1:-status}" ;;
  heartbeat|hb|mesh)  cmd_heartbeat ;;
  *)
    if get_agent "$1" > /dev/null 2>&1; then
      cmd_launch "$1" "${2:-}" "$TOOL_OVERRIDE"
    else
      echo -e "${R}Unknown: $1${N}" >&2
      echo -e "${D}Try: convergio as $1 | convergio list${N}"
      exit 1
    fi ;;
esac
