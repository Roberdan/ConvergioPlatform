#!/usr/bin/env zsh
# convergio — ConvergioPlatform Swarm CLI v2.0.0
# Model-agnostic, tool-agnostic, machine-agnostic agent orchestration
# All state managed by daemon core on :8420
set -euo pipefail

PLATFORM_DIR="${CONVERGIO_PLATFORM_DIR:-$HOME/GitHub/ConvergioPlatform}"
TOGGLE="$PLATFORM_DIR/scripts/platform/convergio-toggle.sh"
BUS="$PLATFORM_DIR/scripts/platform/convergio-bus.sh"
DAEMON_URL="${CONVERGIO_DAEMON_URL:-http://localhost:8420}"

R='\033[0;31m'; G='\033[0;32m'; Y='\033[0;33m'
C='\033[0;36m'; B='\033[1m'; D='\033[2m'; N='\033[0m'

# name|description|invoke|default_model|default_tool
AGENT_LIST=(
  "planner|Plan creation + orchestration|/planner|opus|claude"
  "executor|Task execution with TDD|/execute|codex|copilot"
  "thor|Quality validation (10 gates)|/validate|opus|claude"
  "prompt|Requirements extraction|/prompt|opus|claude"
  "reviewer|Independent plan review|@plan-reviewer|sonnet|claude"
  "rex|Code review — patterns + security|@rex-code-reviewer|haiku|claude"
  "debugger|Adversarial 3-hypothesis debugging|@adversarial-debugger|sonnet|claude"
  "postmortem|Plan execution analysis|@plan-post-mortem|opus|claude"
  "optimizer|Context + token optimization|/optimize-instructions|opus|claude"
  "auditor|Deep cross-validated repo audit|@deep-repo-auditor|opus|claude"
  "convergio|Platform control plane expert|@Convergio|sonnet|claude"
  "llm|Local LLM infrastructure|@ConvergioLLM|sonnet|claude"
  "check|Quick session status recap|/check|mini|copilot"
  "ali|Chief of Staff — orchestrates virtual teams|@ali-orchestrator|opus|claude"
)

get_agent() {
  for entry in "${AGENT_LIST[@]}"; do
    [[ "${entry%%|*}" == "$1" ]] && echo "$entry" && return 0
  done
  return 1
}

_daemon_ok() { curl -sf --connect-timeout 1 "$DAEMON_URL/api/ipc/status" > /dev/null 2>&1; }

cmd_help() {
  echo -e "${B}convergio${N} — Swarm CLI v2.0.0\n"
  echo -e "${B}Solve (virtual organization):${N}"
  echo -e "  convergio ${C}solve \"problem\"${N}            Ali assembles a team and solves it"
  echo -e "\n${B}Agents (any model/tool):${N}"
  echo -e "  convergio ${C}<agent> [name] [--tool T]${N}  Launch (tools: claude|copilot|opencode|local)"
  echo -e "  convergio ${C}as <name> [--tool T]${N}       Custom name"
  echo -e "  convergio ${C}list${N}                       Available agents"
  echo -e "  convergio ${C}menu${N}                       Interactive"
  echo -e "\n${B}Communication (daemon API):${N}"
  echo -e "  convergio ${C}who${N}                        Active agents"
  echo -e "  convergio ${C}msg <from> <to> <msg>${N}      Send message"
  echo -e "  convergio ${C}read <name>${N}                Read messages"
  echo -e "  convergio ${C}broadcast <from> <msg>${N}     Send to all"
  echo -e "\n${B}Toggle:${N}"
  echo -e "  convergio ${C}on|off|status${N}              Enable/disable/check"
  echo -e "\n${B}Workflow:${N}"
  echo -e "  convergio ${C}plans|session${N}              Plan status"
  echo -e "  convergio ${C}autopilot [watch]${N}          Auto execute→Thor→merge loop"
  echo -e "  convergio ${C}auto-update${N}                Analyze + propose improvements"
  echo -e "\n${B}Telemetry & Learning:${N}"
  echo -e "  convergio ${C}models|metrics|skills|alerts${N}"
  echo -e "  convergio ${C}learnings [analyze|promote]${N} Knowledge system"
  echo -e "  convergio ${C}collect-metrics${N}             Snapshot system telemetry"
  echo -e "  convergio ${C}watch-agents${N}               Real-time agent activity stream"
  echo -e "\n${B}Maintenance:${N}"
  echo -e "  convergio ${C}sync-agents|import-agents${N}"
  echo -e "  convergio ${C}heartbeat${N}                  Mesh status"
}

cmd_list() {
  echo -e "${B}Available Agents${N}\n"
  printf "  ${B}%-12s %-38s %-8s %s${N}\n" "NAME" "ROLE" "MODEL" "TOOL"
  echo "  ──────────── ────────────────────────────────────── ──────── ────────"
  for entry in "${AGENT_LIST[@]}"; do
    IFS='|' read -r name desc invoke model tool <<< "$entry"
    printf "  ${C}%-12s${N} %-38s ${D}%-8s %s${N}\n" "$name" "$desc" "$model" "$tool"
  done
  echo -e "\n${D}convergio <name> [custom-name] [--tool claude|copilot|opencode]${N}"
}

cmd_menu() {
  echo -e "${B}Convergio — Select Agent${N}\n"
  local i=1 names=()
  for entry in "${AGENT_LIST[@]}"; do
    IFS='|' read -r name desc invoke model tool <<< "$entry"
    printf "  ${C}%2d${N}. %-12s %s ${D}(%s/%s)${N}\n" "$i" "$name" "$desc" "$model" "$tool"
    names+=("$name")
    i=$((i + 1))
  done
  echo ""
  echo -ne "${B}Agent (number/name): ${N}"; read -r choice
  echo -ne "${B}Custom name (Enter=default): ${N}"; read -r cname
  echo -ne "${B}Tool (Enter=default): ${N}"; read -r ctool

  local selected
  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#names[@]} )); then
    selected="${names[$choice]}"
  else
    selected="$choice"
  fi
  cmd_launch "$selected" "${cname:-}" "${ctool:-}"
}

cmd_launch() {
  local agent="$1" custom_name="${2:-}" custom_tool="${3:-}"
  local entry
  entry=$(get_agent "$agent") || { echo -e "${R}Unknown: $agent${N}" >&2; return 1; }

  IFS='|' read -r name desc invoke model default_tool <<< "$entry"
  local sname="${custom_name:-$name}"
  local tool="${custom_tool:-$default_tool}"

  "$TOGGLE" on 2>/dev/null
  "$BUS" register "$sname" "$desc" "$tool" 2>/dev/null || true

  export CONVERGIO_AGENT_NAME="$sname"

  echo -e "${G}Launching ${B}$sname${N}${G} ($desc)${N}"
  echo -e "${D}Model: $model | Tool: $tool | Invoke: $invoke${N}\n"

  local p="Il tuo nome è ${sname}. Ruolo: ${desc}. "
  p+="MESSAGING: I messaggi in arrivo ti vengono mostrati automaticamente. "
  p+="Per inviare: convergio-bus.sh send ${sname} <destinatario> <messaggio>. "
  p+="Per vedere chi è online: convergio-bus.sh who. "
  [[ "$invoke" == /* ]] && p+="Esegui $invoke per iniziare." || p+="Lavora secondo il tuo ruolo."

  _launch_tool "$tool" "$p"
  "$BUS" unregister "$sname" 2>/dev/null || true
}

cmd_solve() {
  # Parse flags
  local autonomy="approve-plan"  # default: approve plan, then auto-execute
  local goal_parts=()
  for arg in "$@"; do
    case "$arg" in
      --autonomous)    autonomy="autonomous" ;;
      --approve-each)  autonomy="approve-each" ;;
      --approve-plan)  autonomy="approve-plan" ;;
      *)               goal_parts+=("$arg") ;;
    esac
  done
  local goal="${goal_parts[*]}"
  [ -z "$goal" ] && { echo -e "${R}Usage: convergio solve \"problem\" [--autonomous|--approve-plan|--approve-each]${N}"; return 1; }

  export CONVERGIO_AGENT_NAME="ali"
  "$TOGGLE" on 2>/dev/null
  "$BUS" register "ali" "orchestrator" "claude" 2>/dev/null || true

  echo -e "${B}Convergio Solve${N}"
  echo -e "${D}Goal: $goal${N}"
  echo -e "${D}Autonomy: $autonomy${N}"
  echo -e "${G}Spawning Ali (Chief of Staff, Opus)...${N}\n"

  local p="Sei Ali, il Chief of Staff di Convergio. "
  p+="PROBLEMA: $goal "
  p+="MODALITA: $autonomy "
  case "$autonomy" in
    autonomous)   p+="Esegui tutto senza chiedere approvazione. Solo escalate su 3x failure. " ;;
    approve-plan) p+="Presenta il piano per approvazione, poi esegui tutto automaticamente. Ferma solo pre-merge. " ;;
    approve-each) p+="Chiedi approvazione PRIMA di ogni dispatch di agente e PRIMA di ogni merge. " ;;
  esac
  p+="ISTRUZIONI: "
  p+="1) Analizza il problema — dominio, complessita, ruoli. "
  p+="2) Cerca agenti: sqlite3 \$DASHBOARD_DB \"SELECT ac.name, ac.category, ac.model, ask.confidence, substr(ac.description,1,60) FROM agent_catalog ac JOIN agent_skills ask ON ac.name=ask.agent_name WHERE ask.skill IN ('keyword') ORDER BY ask.confidence DESC;\" "
  p+="3) Assembla team (confidence-weighted). "
  p+="4) Invoca /planner per il piano (SEMPRE per 3+ task). "
  p+="5) Per ogni task, scegli il validatore corretto per output_type (Thor per code, doc-validator per documenti, strategy-validator per analisi, design-validator per design, compliance-validator per legal). "
  p+="6) Dispatcha agenti. Passa output tra agenti via shared context. "
  p+="7) Monitora, re-dispatcha su failure (max 3 tentativi per task). "
  p+="8) Riporta risultati con metriche. "
  p+="NON implementare tu — delega SEMPRE agli specialisti."

  _launch_tool "claude" "$p"
  "$BUS" unregister "ali" 2>/dev/null || true
}

cmd_stop() {
  local run_id="${1:-}"
  echo -e "${Y}Stopping active execution...${N}"
  "$BUS" broadcast "ali" "ABORT: User requested stop" 2>/dev/null || true
  if [ -n "$run_id" ]; then
    sqlite3 "${DASHBOARD_DB:-$PLATFORM_DIR/data/dashboard.db}" \
      "UPDATE execution_runs SET status='cancelled', completed_at=datetime('now') WHERE id=$run_id;" 2>/dev/null
    echo "  Run $run_id cancelled"
  fi
  echo "  Broadcast ABORT sent to all agents"
}

cmd_named() {
  local sname="${1:?Usage: convergio as <name> [--tool T]}"
  local tool="${2:-claude}"
  export CONVERGIO_AGENT_NAME="$sname"
  "$TOGGLE" on 2>/dev/null
  "$BUS" register "$sname" "custom agent" "$tool" 2>/dev/null || true
  echo -e "${G}Launching ${B}$sname${N}\n"
  local p="Il tuo nome è ${sname}. Sei un agente Convergio. Usa convergio-bus.sh per comunicare."
  _launch_tool "$tool" "$p"
  "$BUS" unregister "$sname" 2>/dev/null || true
}

_launch_tool() {
  local tool="$1" prompt="$2"
  # Set agent name in env so hooks can check inbox
  export CONVERGIO_AGENT_NAME="${CONVERGIO_AGENT_NAME:-agent}"
  case "$tool" in
    claude)
      command -v claude &>/dev/null && { claude -p "$prompt" 2>/dev/null || claude; } \
        || { echo -e "${Y}Claude CLI not found${N}"; echo "$prompt"; } ;;
    copilot)
      command -v gh &>/dev/null && { echo "$prompt"; gh copilot 2>/dev/null; } \
        || { echo -e "${Y}gh CLI not found${N}"; echo "$prompt"; } ;;
    opencode)
      command -v opencode &>/dev/null && { echo "$prompt" | opencode 2>/dev/null; } \
        || { echo -e "${Y}OpenCode not found${N}"; echo "$prompt"; } ;;
    local)
      # Local LLM via LiteLLM proxy (convergio-llm.sh must be running)
      local LITELLM_URL="${LITELLM_URL:-http://localhost:4000}"
      if curl -sf "$LITELLM_URL/health" > /dev/null 2>&1; then
        echo -e "${G}Sending to local LLM ($LITELLM_URL)${N}\n"
        curl -sf "$LITELLM_URL/chat/completions" \
          -H "Content-Type: application/json" \
          -d "{\"model\":\"local\",\"messages\":[{\"role\":\"system\",\"content\":\"$prompt\"},{\"role\":\"user\",\"content\":\"Start.\"}]}" \
          2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['choices'][0]['message']['content'])" 2>/dev/null \
          || echo -e "${R}Local LLM request failed${N}"
      else
        echo -e "${Y}Local LLM not running. Start with: convergio-llm.sh start${N}"
        echo "$prompt"
      fi ;;
    *) echo -e "${Y}Unknown tool: $tool${N}"; echo "$prompt" ;;
  esac
}

cmd_who()       { "$BUS" who; }
cmd_msg()       { "$BUS" send "$@"; }
cmd_read_msg()  { "$BUS" read "$@"; }
cmd_broadcast() { "$BUS" broadcast "$@"; }
cmd_models()    { "$BUS" models; }
cmd_metrics()   { "$BUS" metrics; }
cmd_skills()    { "$BUS" skills; }

cmd_alerts() {
  _daemon_ok && curl -sf "$DAEMON_URL/api/dashboard/notifications" 2>/dev/null \
    | python3 -m json.tool 2>/dev/null || echo "Daemon not running or no alerts."
}

cmd_plans() { bash "$PLATFORM_DIR/claude-config/scripts/plan-db.sh" list 1 2>/dev/null || echo "N/A"; }
cmd_session() { bash "$PLATFORM_DIR/claude-config/scripts/session-check.sh" 2>/dev/null | python3 -m json.tool 2>/dev/null || echo "N/A"; }
cmd_learnings() { bash "$PLATFORM_DIR/claude-config/scripts/session-learnings.sh" summary 2>/dev/null || echo "N/A"; }

cmd_auto_update() {
  "$TOGGLE" on 2>/dev/null
  echo -e "${B}Convergio Auto-Update${N}\n"
  local p="Sei context-optimizer + post-mortem. 1) session-learnings.sh summary 2) Web: novita AI 3) claude-config/ inefficienze 4) plan-db.sh get-failures 5) Proponi diff. NO apply senza ok."
  cd "$PLATFORM_DIR"; command -v claude &>/dev/null && claude "$p" || echo "$p"
}

cmd_sync_agents() {
  echo -e "${B}Syncing agent definitions...${N}"
  local src="$PLATFORM_DIR/claude-config/agents"
  echo "  Source: $src (canonical)"
  echo "  Claude: ~/.claude/agents/ (via global symlink)"

  local count=0
  find -L "$src" -name "*.md" | while read f; do
    local aname=$(head -10 "$f" | grep '^name:' | cut -d' ' -f2)
    [ -n "$aname" ] && count=$((count + 1)) && echo "  ✓ $aname"
  done
  echo -e "\n${G}Done.${N}"
}

cmd_heartbeat() { bash "$PLATFORM_DIR/scripts/mesh/mesh-heartbeat.sh" 2>/dev/null || echo "Mesh N/A."; }

# ─── Parse --tool flag ───────────────────────────────────────────────
TOOL_OVERRIDE=""
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--tool" ]]; then TOOL_OVERRIDE="__next__"
  elif [[ "$TOOL_OVERRIDE" == "__next__" ]]; then TOOL_OVERRIDE="$arg"
  else ARGS+=("$arg"); fi
done
set -- "${ARGS[@]:-}"

case "${1:-help}" in
  help|--help|-h)     cmd_help ;;
  list|ls)            cmd_list ;;
  menu|select)        cmd_menu ;;
  on|enable)          "$TOGGLE" on ;;
  off|disable)        "$TOGGLE" off ;;
  status|st)          "$TOGGLE" status; _daemon_ok && echo "  Daemon: running" || echo "  Daemon: stopped" ;;
  as)                 shift; cmd_named "${1:-}" "$TOOL_OVERRIDE" ;;
  who)                cmd_who ;;
  msg|send)           shift; cmd_msg "$@" ;;
  read)               shift; cmd_read_msg "$@" ;;
  broadcast)          shift; cmd_broadcast "$@" ;;
  plans)              cmd_plans ;;
  session|sess)       cmd_session ;;
  learnings)          cmd_learnings ;;
  auto-update|update) cmd_auto_update ;;
  models)             cmd_models ;;
  metrics)            cmd_metrics ;;
  skills)             cmd_skills ;;
  alerts)             cmd_alerts ;;
  sync-agents)        cmd_sync_agents ;;
  solve)              shift; cmd_solve "$@" ;;
  stop)               shift; cmd_stop "${1:-}" ;;
  sync)               shift; bash "$PLATFORM_DIR/scripts/platform/convergio-sync.sh" "$@" ;;
  autopilot)          shift; bash "$PLATFORM_DIR/scripts/platform/convergio-autopilot.sh" "${1:-once}" ;;
  learnings)          shift; bash "$PLATFORM_DIR/scripts/platform/convergio-learnings.sh" "${1:-summary}" ;;
  collect-metrics)    bash "$PLATFORM_DIR/scripts/platform/convergio-metrics.sh" collect ;;
  org)                shift; bash "$PLATFORM_DIR/scripts/platform/convergio-org.sh" "${1:-help}" "${2:-}" ;;
  watch-agents)       echo "Watching agent activity (Ctrl+C to stop)..." ; curl -sf -N "$DAEMON_URL/ws/dashboard" 2>/dev/null | python3 -c "
import sys,json
for line in sys.stdin:
  line=line.strip()
  if not line: continue
  try:
    d=json.loads(line)
    t=d.get('type','?')
    if 'agent' in t or 'ipc' in t:
      print(f'[{t}] {json.dumps(d,indent=None)}')
  except: pass
" 2>/dev/null || echo "Daemon not running or WS not available. Start daemon first." ;;
  import-agents)      shift; bash "$PLATFORM_DIR/scripts/platform/convergio-import-agents.sh" "${1:-}" ;;
  heartbeat|hb|mesh)  cmd_heartbeat ;;
  *)
    if get_agent "$1" > /dev/null 2>&1; then
      cmd_launch "$1" "${2:-}" "$TOOL_OVERRIDE"
    else
      echo -e "${R}Unknown: $1${N}" >&2
      echo -e "${D}Try: convergio as $1 | convergio list${N}"
      exit 1
    fi ;;
esac
