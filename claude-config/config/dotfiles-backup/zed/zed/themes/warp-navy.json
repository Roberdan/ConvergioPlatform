{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Warp Navy",
  "author": "Roberto",
  "themes": [
    {
      "name": "Warp Navy",
      "appearance": "dark",
      "style": {
        "background": "#0d2045",
        "editor.background": "#0d2045",
        "editor.gutter.background": "#0d2045",
        "editor.active_line.background": "#152a55",
        "editor.line_number": "#4a6080",
        "editor.active_line_number": "#ffffff",

        "text": "#ffffff",
        "text.muted": "#8899bb",
        "text.accent": "#a5d5fe",

        "border": "#1a3060",
        "border.variant": "#254080",
        "border.focused": "#a5d5fe",
        "border.selected": "#a5d5fe",

        "elevated_surface.background": "#102550",
        "surface.background": "#0a1835",
        "panel.background": "#0a1835",
        "status_bar.background": "#0a1835",
        "title_bar.background": "#0a1835",
        "toolbar.background": "#0d2045",
        "tab_bar.background": "#0a1835",
        "tab.active_background": "#0d2045",
        "tab.inactive_background": "#0a1835",

        "element.hover": "#152a55",
        "element.selected": "#1a3565",
        "ghost_element.hover": "#152a55",
        "ghost_element.selected": "#1a3565",

        "scrollbar.thumb.background": "#254080",
        "scrollbar.thumb.hover_background": "#3060a0",
        "scrollbar.track.background": "#0d2045",

        "link_text.hover": "#c1e3fe",

        "players": [
          { "cursor": "#ffffff", "selection": "#254080", "background": "#a5d5fe" }
        ],

        "syntax": {
          "keyword": { "color": "#ff8ffd" },
          "function": { "color": "#a5d5fe" },
          "type": { "color": "#b4fa72" },
          "string": { "color": "#b4fa72" },
          "number": { "color": "#fefdc2" },
          "comment": { "color": "#6080a0" },
          "variable": { "color": "#ffffff" },
          "constant": { "color": "#fefdc2" },
          "punctuation": { "color": "#d0d1fe" },
          "operator": { "color": "#d0d1fe" },
          "property": { "color": "#a5d5fe" },
          "tag": { "color": "#ff8272" },
          "attribute": { "color": "#fefdc2" }
        },

        "terminal.background": "#0d2045",
        "terminal.foreground": "#ffffff",
        "terminal.ansi.black": "#616161",
        "terminal.ansi.red": "#ff8272",
        "terminal.ansi.green": "#b4fa72",
        "terminal.ansi.yellow": "#fefdc2",
        "terminal.ansi.blue": "#a5d5fe",
        "terminal.ansi.magenta": "#ff8ffd",
        "terminal.ansi.cyan": "#d0d1fe",
        "terminal.ansi.white": "#f1f1f1",
        "terminal.ansi.bright_black": "#8e8e8e",
        "terminal.ansi.bright_red": "#ffc4bd",
        "terminal.ansi.bright_green": "#d6fcb9",
        "terminal.ansi.bright_yellow": "#fefdd5",
        "terminal.ansi.bright_blue": "#c1e3fe",
        "terminal.ansi.bright_magenta": "#ffb1fe",
        "terminal.ansi.bright_cyan": "#e5e6fe",
        "terminal.ansi.bright_white": "#feffff"
      }
    }
  ]
}
