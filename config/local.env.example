# ConvergioPlatform Local Config — copy to config/local.env and customize
# This file is committed as a template. config/local.env is gitignored.
# Never commit local.env.

# Mesh coordinator
MESH_COORDINATOR_HOST=your-coordinator.your-tailnet.ts.net
MESH_COORDINATOR_USER=your-username

# Worker nodes (comma-separated for multi-node scripts)
MESH_WORKERS="worker1,worker2,worker3"

# Node aliases (used by mesh scripts)
NODE_M3_HOST=your-worker-1.your-tailnet.ts.net
NODE_M3_USER=your-username
NODE_M1_HOST=your-worker-2.your-tailnet.ts.net
NODE_M1_USER=your-username
NODE_OMARCHY_HOST=your-linux-worker.your-tailnet.ts.net
NODE_OMARCHY_USER=your-username
NODE_LINUX_ALIAS_LOCAL=your-linux-local
NODE_LINUX_ALIAS_TS=your-linux-ts

# GitHub account routing
GH_DEFAULT_ACCOUNT=YourGitHubAccount
GH_MICROSOFT_ACCOUNT=your-github-work-account
GH_MICROSOFT_REPOS="YourWorkRepo"
GH_OTHER_ACCOUNTS=""

# Default deploy targets
DEPLOY_PEER=your-linux-ts
AUDIT_REMOTE=your-linux-ts

# Tailscale domain suffix
TS_DOMAIN=your-tailnet.ts.net

# Database
DASHBOARD_DB=~/GitHub/ConvergioPlatform/data/dashboard.db
