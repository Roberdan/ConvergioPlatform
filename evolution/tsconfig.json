{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": [
    "core/**/*.ts",
    "adapters/**/*.ts",
    "telemetry/**/*.ts",
    "agents/**/*.ts",
    "integrations/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
